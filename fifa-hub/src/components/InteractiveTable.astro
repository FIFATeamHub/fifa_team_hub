---
// Componente interativo para a tabela de ferramentas
---

<div class="interactive-table-container">
  <table class="interactive-table">
    <thead>
      <tr>
        <th>Ferramenta</th>
        <th>Uso no Projeto</th>
        <th>Frequência</th>
      </tr>
    </thead>
    <tbody>
      <tr class="tool-row" data-tool="whatsapp">
        <td>📱 <strong>WhatsApp</strong></td>
        <td>Avisos rápidos e comunicação urgente</td>
        <td>Diário</td>
      </tr>
      <tr class="tool-row" data-tool="discord">
        <td>🎮 <strong>Discord</strong></td>
        <td>Reuniões, alinhamentos e pareamento de código</td>
        <td>Semanal</td>
      </tr>
      <tr class="tool-row" data-tool="github">
        <td>🐙 <strong>GitHub</strong></td>
        <td>Gestão do repositório da Organização</td>
        <td>Diário</td>
      </tr>
      <tr class="tool-row" data-tool="docker">
        <td>🐳 <strong>Docker</strong></td>
        <td>Containerização do banco e padronização do ambiente</td>
        <td>Contínuo</td>
      </tr>
      <tr class="tool-row" data-tool="dbeaver">
        <td>🦫 <strong>DBeaver</strong></td>
        <td>Gerenciamento e consultas ao PostgreSQL</td>
        <td>Contínuo</td>
      </tr>
      <tr class="tool-row" data-tool="postman">
        <td>🚀 <strong>Postman</strong></td>
        <td>Testes e consumo das rotas da API</td>
        <td>Contínuo</td>
      </tr>
      <tr class="tool-row" data-tool="dbdiagram">
        <td>📊 <strong>dbdiagram.io</strong></td>
        <td>Modelagem e esboço do diagrama de entidades (DER)</td>
        <td>Pontual</td>
      </tr>
    </tbody>
  </table>
</div>

<style>
  .interactive-table-container {
    margin: 1rem 0;
  }
  
  .interactive-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    background: transparent;
  }
  
  .interactive-table th,
  .interactive-table td {
    padding: 12px 16px;
    text-align: left;
    border: 1px solid var(--sl-color-gray-4);
  }
  
  .interactive-table th {
    /* Fundo Azul FIFA */
    background: var(--fifa-blue, #3B82F6);
    color: white;
    font-weight: 600;
    font-size: 0.9em;
  }
  
  .interactive-table td {
    font-size: 0.95em;
    background: transparent;
  }
  
  .tool-row {
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  
  .tool-row:hover {
    /* Hover com Azul FIFA suave */
    background: rgba(59, 130, 246, 0.1);
  }
  
  .tool-row.active {
    /* Linha ativa com Verde FIFA para destaque de seleção */
    background: rgba(16, 185, 129, 0.15);
    border-left: 3px solid var(--fifa-green, #10B981);
  }
</style>

<script>
  // Interatividade para a tabela
  document.addEventListener('DOMContentLoaded', function() {
    const rows = document.querySelectorAll('.tool-row');
    
    rows.forEach(row => {
      row.addEventListener('click', function(this: HTMLTableRowElement) {
        // Remove active class from all rows
        rows.forEach(r => {
          r.classList.remove('active');
          // Limpa a borda customizada das outras linhas
          (r as HTMLElement).style.borderLeft = '';
        });
        
        // Add active class to clicked row
        this.classList.add('active');
        
        // Show tool info
        const tool = this.getAttribute('data-tool');
        console.log(`Ferramenta selecionada: ${tool}`);
      });
    });
  });
</script>