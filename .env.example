# DataBase
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Frontend
VITE_API_URL=

# Backend

FLASK_ENV=
SECRET_KEY=

# Deixe em branco em dev para liberar localhost + IPs de rede local automaticamente.
# Em produção, defina com a URL do frontend (é isso que o cloudbuild.yaml injeta).
CORS_ALLOWED_ORIGINS=

# Autenticação JWT
JWT_SECRET_KEY=troque-por-uma-chave-segura-em-producao-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


#Storage GCS

STORAGE_BACKEND=gcs

GCS_BUCKET_NAME=
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/app/config/fifa-team-hub-key.json
# Host usado para montar a signed URL devolvida ao navegador (dev local com fake-gcs).
# Deixe em branco em produção — o client usa storage.googleapis.com automaticamente.
GCS_PUBLIC_URL=

LOCAL_STORAGE_PATH=
MAX_FILE_SIZE_MB=
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,docx

#Storage Local
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=./storage/uploads
# MAX_FILE_SIZE_MB=10
# ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,docx